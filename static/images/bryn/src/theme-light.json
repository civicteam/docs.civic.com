    "fontSize": "16px",
    "primaryColor": "#F8FAFC",
    "primaryTextColor": "#1F2937",
    "primaryBorderColor": "#94A3B8",
    "lineColor": "#94A3B8",
    "secondaryColor": "#F8FAFC",
    "tertiaryColor": "#F8FAFC",
    "edgeLabelBackground": "#FFFFFF",
    "clusterBkg": "transparent",
    "clusterBorder": "#94A3B8",
    "titleColor": "#1F2937"
